# Supabase credentials
SUPABASE_URL=faked_supabase_url
SUPABASE_ANON_KEY=faked_supabase_anon_key
SUPABASE_SERVICE_KEY=faked_service_key
# Database URL for Drizzle ORM
# Format: postgres://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:6543/postgres
# Replace [YOUR-PASSWORD] and [YOUR-HOST] with your Supabase database credentials
# You can find this in your Supabase dashboard under Settings > Database
# WX9yRjzbYMilOPU7
# DATABASE_URL=postgresql://postgres:WX9yRjzbYMilOPU7@zbpdcaherdfgxctgsvou.supabase.co:5432/postgres
# Connect to Supabase via connection pooling
DATABASE_URL=faked_database_url

# Direct connection to the database. Used for migrations
DATABASE_MIGRATION_URL=faked_migration_url

# JWT Configuration
JWT_SECRET=change_this  # Must be secure and kept secret in production!
JWT_EXPIRY=24h  # Token expiry time
OPENAI_API_KEY=faked_open_api_key